# ============================================================
# ResearchBot Pro — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# ============================================================

# --- OpenAI (required) ---
# Used by CrewAI agents for LLM calls (gpt-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Serper (required) ---
# Web search API used by Agent A (Searcher)
# Get a free key at https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# --- Supabase (optional — app works without it using in-memory storage) ---
# Create a free project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# --- LangSmith (optional — enables tracing & observability) ---
# Sign up at https://smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=researchbot-pro
LANGSMITH_TRACING_V2=true

# --- Application Settings ---
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
